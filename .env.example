# Supabase 接続情報
# このファイルをコピーして .env を作り、実際のキーを書く
# .env はgit管理対象外（.gitignoreで除外済み）

SUPABASE_URL=https://urzflutzgcioqswzmpkz.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 認証ゲート（workspace-hub の JWT を JWKS 検証）
# 既定は「監視のみ」でブロックしない。本番は値を入れなくても現挙動のまま動く。
# JWKS_URL             JWKS エンドポイント（未設定なら https://auth.utinc.dev/.well-known/jwks.json）
# AUTH_EXPECTED_ISSUER 期待する iss（未設定なら https://auth.utinc.dev）。署名に加え発行者を照合し、なりすましを二重防御
# AUTH_ENFORCE         "on" にすると未認証/検証失敗/権限不足を 401/403 でブロック。未設定/off は監視のみ
# AUTH_SYSTEM_KEY      自アプリのシステムキー（未設定なら "nexus" = workspace-hub SYSTEM_CATALOG のキー）。enforce 時 systems[] と照合
# JWKS_URL=https://auth.utinc.dev/.well-known/jwks.json
# AUTH_EXPECTED_ISSUER=https://auth.utinc.dev
# AUTH_ENFORCE=off
# AUTH_SYSTEM_KEY=nexus

# 動作モード（プラットフォーム版 / 単体販売版）
# STANDALONE             "1"/"true"/"on"/"yes" で単体販売版。未設定/その他はプラットフォーム版（既定）。
#                        単体版では wh SSO ゲートをスキップする（wh JWT を使わない）。
#                        ※ nexus の単体版「自前ログイン」は未整備（要実装）。現状フラグ ON は
#                          ゲートスキップ＋テナント固定のみ有効（ログイン UI は別途実装が必要）。
# STANDALONE_TENANT_ID   単体版の固定テナント UUID。単体版では全データをこのテナントに揃える
#                        （単一顧客＝1 テナント）。STANDALONE 時は必須（未設定だと fail-closed）。
# STANDALONE=true
# STANDALONE_TENANT_ID=00000000-0000-0000-0000-000000000000
